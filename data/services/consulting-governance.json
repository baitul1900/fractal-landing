    "serviceProcess": {
        "badgeText": "Our Process",
        "headerText": {
            "fullText": "A Clear, Proven Framework for Enterprise Cloud Delivery",
            "highlight": ""
        },
        "subText": "Our cloud delivery process is designed to ensure reliability, security, and operational continuity throughout every phase of cloud adoption. Each stage produces clear outputs, enabling controlled execution and long-term stability.",
        "isArchitecture": true,
        "steps": [
            {
                "id": 1,
                "stage": "Stage 1",
                "title": "Context & Initiative Definition",
                "description": "Clarify objectives, scope boundaries, constraints, stakeholders, and delivery expectations.",
                "output": "Defined initiative scope, success criteria, and governance context"
            },
            {
                "id": 2,
                "stage": "Stage 2",
                "title": "Delivery Planning & Risk Structuring",
                "description": "Create delivery plans, dependency maps, risk registers, and decision checkpoints.",
                "output": "Delivery roadmap with risk & dependency visibility"
            },
            {
                "id": 3,
                "stage": "Stage 3",
                "title": "Governance Structure & Decision Control",
                "description": "Establish decision rights, escalation paths, reporting cadence, and control mechanisms.",
                "output": "Active governance framework with clear ownership"
            },
            {
                "id": 4,
                "stage": "Stage 4",
                "title": "Execution Oversight & Issue Management",
                "description": "Monitor progress, manage risks, coordinate vendors and teams, and resolve blockers.",
                "output": "Controlled execution with ongoing issue resolution"
            },
            {
                "id": 5,
                "stage": "Stage 5",
                "title": "Change, Scope & Impact Management",
                "description": "Assess and govern scope changes, trade-offs, and impact on time, cost, and risk.",
                "output": "Managed change with transparent decision records"
            },
            {
                "id": 6,
                "stage": "Stage 6",
                "title": "Delivery Closure & Transition",
                "description": "Support controlled handover, lessons learned, and operational transition.",
                "output": "Closed initiatives with clear ownership & accountability"
            }
        ]
    },
