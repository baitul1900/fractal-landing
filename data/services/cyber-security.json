    "serviceProcess": {
        "badgeText": "Our Process",
        "headerText": {
            "fullText": "A Practical Approach to Security and Compliance",
            "highlight": "Security and Compliance"
        },
        "subText": "Security and compliance fail when controls are added without understanding how systems and teams actually operate. Our approach reduces risk while keeping systems usable, auditable, and stable.",
        "isArchitecture": true,
        "steps": [
            {
                "id": 1,
                "stage": "Stage 1",
                "title": "Environment & Risk Context Review",
                "description": "Assess systems, data flows, access points, and regulatory exposure.",
                "output": "Security and compliance risk overview"
            },
            {
                "id": 2,
                "stage": "Stage 2",
                "title": "Control & Compliance Mapping",
                "description": "Map required security controls and compliance obligations to real system workflows.",
                "output": "Control framework aligned to regulations and operations"
            },
            {
                "id": 3,
                "stage": "Stage 3",
                "title": "Security Design & Implementation Guidance",
                "description": "Design access controls, security policies, and enforcement mechanisms.",
                "output": "Implemented security controls and documented policies"
            },
            {
                "id": 4,
                "stage": "Stage 4",
                "title": "Compliance Readiness & Evidence Setup",
                "description": "Prepare documentation, audit trails, and evidence structures.",
                "output": "Audit-ready compliance artifacts"
            },
            {
                "id": 5,
                "stage": "Stage 5",
                "title": "Monitoring & Incident Readiness",
                "description": "Define monitoring practices and response procedures without operational disruption.",
                "output": "Operational security and incident readiness plan"
            },
            {
                "id": 6,
                "stage": "Stage 6",
                "title": "Ongoing Review & Adjustment",
                "description": "Review controls as systems, regulations, and risks evolve.",
                "output": "Sustained security posture and compliance alignment"
            }
        ]
    },
