    "serviceProcess": {
        "badgeText": "Our Process",
        "headerText": {
            "fullText": "A Structured Approach to Reliable Data and Usable Analytics",
            "highlight": ""
        },
        "subText": "Data initiatives fail when structure is skipped, ownership is unclear, or analytics are built without decision context. Our approach establishes data clarity first, then enables analytics that teams can actually rely on.",
        "isArchitecture": true,
        "steps": [
            {
                "id": 1,
                "stage": "Stage 1",
                "title": "Context & Data Landscape Assessment",
                "description": "Understand business goals, decision needs, existing data sources, and current data issues.",
                "output": "Data landscape overview and decision requirements map"
            },
            {
                "id": 2,
                "stage": "Stage 2",
                "title": "Data Structure & Definition",
                "description": "Define data models, key metrics, shared definitions, and ownership across systems and teams.",
                "output": "Core data definitions and structural data model"
            },
            {
                "id": 3,
                "stage": "Stage 3",
                "title": "Analytics & Use Case Prioritization",
                "description": "Identify analytics use cases that directly support operational and leadership decisions.",
                "output": "Prioritized analytics use cases and success criteria"
            },
            {
                "id": 4,
                "stage": "Stage 4",
                "title": "Data Quality, Access & Governance Setup",
                "description": "Establish data quality rules, access controls, and governance processes to maintain trust over time.",
                "output": "Data quality framework and governance guidelines"
            },
            {
                "id": 5,
                "stage": "Stage 5",
                "title": "Analytics Enablement & Reporting Guidance",
                "description": "Support analytics implementation and reporting design aligned with agreed definitions and governance.",
                "output": "Analytics-ready data guidance and reporting structure"
            },
            {
                "id": 6,
                "stage": "Stage 6",
                "title": "Ongoing Data Review & Evolution Support",
                "description": "Review data usage, adjust definitions, and support evolving analytics needs as systems change.",
                "output": "Sustained data clarity & long-term analytics alignment"
            }
        ]
    },
